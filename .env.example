# Shared paid-ads-analytics service account JSON, stringified.
# Same value as the GitHub Actions secret in both pipeline repos.
GOOGLE_SHEETS_CREDS_JSON=

# Spreadsheet IDs the dashboard reads from.
META_SPREADSHEET_ID=
GOOGLE_ADS_SPREADSHEET_ID=

# ── Auth gate ──────────────────────────────────────────────────────
# Shared password for the team. Anyone with this gets in.
# Rotate by changing both this var and AUTH_SECRET (the latter
# invalidates every existing session).
DASHBOARD_PASSWORD=

# Random ≥32 chars used to sign the auth cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Rotating this forces every session to log in again.
AUTH_SECRET=
